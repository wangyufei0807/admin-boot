# ============================================
# Admin-Boot 环境变量配置模板
# ============================================
# 说明：复制此文件为 .env 或 .env.local，然后根据实际环境修改
# 注意：.env 文件包含敏感信息，请勿提交到版本控制
# ============================================

# ============================================
# 数据库配置
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=admin_boot
DB_USERNAME=root
# ⚠️ 重要：修改为强密码（至少 12 个字符，包含大小写字母、数字、特殊符号）
DB_PASSWORD=your_secure_password_here

# ============================================
# Redis 配置
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
# ⚠️ 重要：设置 Redis 密码，生产环境必需
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0

# ============================================
# JWT 配置
# ============================================
# ⚠️ 关键：JWT 密钥必须满足以下要求
# - 长度 >= 256 bits（32 字节）
# - 使用强随机值，不要使用预定义值
# - 每个环境使用不同的密钥
# 生成命令：openssl rand -base64 32
JWT_SECRET=your_256_bit_random_secure_key_here_min_32_bytes

# ============================================
# 文件上传配置
# ============================================
FILE_UPLOAD_PATH=/data/upload
FILE_STORAGE_TYPE=local
# 可选值：local（本地存储）、oss（阿里云 OSS）、s3（AWS S3）

# ============================================
# Spring 配置
# ============================================
SPRING_PROFILES_ACTIVE=dev
# 可选值：dev（开发）、test（测试）、prod（生产）

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=INFO
# 可选值：DEBUG、INFO、WARN、ERROR

# ============================================
# JVM 配置
# ============================================
JAVA_OPTS=-server -Xms256m -Xmx512m -XX:+UseG1GC -Djava.security.egd=file:/dev/./urandom

# ============================================
# 应用配置
# ============================================
APP_PORT=8080
APP_CONTEXT_PATH=/
APP_NAME=admin-boot
